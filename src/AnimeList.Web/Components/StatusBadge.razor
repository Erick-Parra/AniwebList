@using AnimeList.Web.Models

<span class="status-badge" style="background:@BgColor;color:@TextColor">@Label</span>

@code {
    [Parameter] public WatchStatus Status { get; set; }

    private string Label => Status switch
    {
        WatchStatus.Watching   => "Viendo",
        WatchStatus.Completed  => "Completado",
        WatchStatus.PlanToWatch => "Por ver",
        WatchStatus.OnHold     => "En pausa",
        WatchStatus.Dropped    => "Abandonado",
        _ => ""
    };

    private string TextColor => Status switch
    {
        WatchStatus.Watching    => "var(--status-watching)",
        WatchStatus.Completed   => "var(--status-completed)",
        WatchStatus.PlanToWatch => "var(--status-plan)",
        WatchStatus.OnHold      => "var(--status-onhold)",
        WatchStatus.Dropped     => "var(--status-dropped)",
        _ => "var(--color-text-muted)"
    };

    private string BgColor => Status switch
    {
        WatchStatus.Watching    => "rgba(99,102,241,.15)",
        WatchStatus.Completed   => "rgba(34,197,94,.15)",
        WatchStatus.PlanToWatch => "rgba(139,92,246,.15)",
        WatchStatus.OnHold      => "rgba(245,158,11,.15)",
        WatchStatus.Dropped     => "rgba(239,68,68,.15)",
        _ => "var(--color-border)"
    };
}
